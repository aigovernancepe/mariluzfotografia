---
import BaseLayout from '../layouts/BaseLayout.astro';
import Capsule from '../components/Capsule.astro';
---

<BaseLayout
  title="Datenschutz — Mariluz Fotografía"
  description="Datenschutzerklärung von Mariluz Fotografía nach revDSG und DSGVO."
  path="/datenschutz/"
>
  <div class="mx-auto max-w-3xl px-5 pt-16">
    <h1 class="text-4xl">Datenschutz</h1>
  </div>
  <Capsule
    question="Wie gehe ich mit Ihren Daten um?"
    answer="Ihre Angaben aus einer Anfrage nutze ich ausschliesslich, um Ihre Anfrage zu bearbeiten. Die vollständige Datenschutzerklärung nach revDSG und DSGVO — inklusive Foto-Freigabe für die Veröffentlichung von Bildern — folgt vor dem Live-Gang."
  >
    <!-- TODO: vollständige revDSG/DSGVO-Erklärung + Foto-Release-Workflow -->
  </Capsule>
</BaseLayout>
