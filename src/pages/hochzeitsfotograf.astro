---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import Capsule from '../components/Capsule.astro';
import { SITE } from '../consts';
import { service } from '../lib/schema';

const alternates = [
  { lang: 'de-CH', href: `${SITE.url}/hochzeitsfotograf/` },
  { lang: 'es', href: `${SITE.url}/es/fotografo-bodas/` },
];

const regions = [
  { label: 'Basel', href: '/hochzeitsfotograf-basel/' },
  { label: 'Aargau', href: '/hochzeitsfotograf-aargau/' },
];
---

<BaseLayout
  title="Hochzeitsfotograf — Foto & Video | Mariluz Fotografía"
  description="Hochzeitsfotografin für authentische, zeitlose Hochzeitsbilder — Foto und Video aus einer Hand, in der ganzen Deutschschweiz. Über 20 Jahre Erfahrung."
  path="/hochzeitsfotograf/"
  alternates={alternates}
  schema={service({
    name: 'Hochzeitsfotografie & -video',
    description: 'Foto- und Videobegleitung für Hochzeiten in der Deutschschweiz.',
    serviceType: 'Hochzeitsfotografie',
  })}
>
  <Hero
    eyebrow="Hochzeit · Foto & Video"
    title="Ihre Hochzeitsfotografin für den schönsten Tag"
    lead="Von den ersten Vorbereitungen bis zum letzten Tanz begleite ich Ihre Hochzeit mit Foto und Video — unaufdringlich, mit dem Blick für echte Momente und über 20 Jahren Erfahrung. In der ganzen Deutschschweiz."
    ctaHref="/kontakt/"
    ctaLabel="Verfügbarkeit anfragen"
  />

  <Capsule
    question="Wie begleite ich Ihre Hochzeit?"
    answer="Ich bin den ganzen Tag dabei, ohne im Weg zu stehen — für die stillen Blicke ebenso wie für die grossen Momente. So entstehen ehrliche, ungestellte Hochzeitsbilder statt steifer Posen. Foto und Video aus einer Hand; nach über 20 Jahren spüre ich, wann der richtige Augenblick kommt."
  />

  <Capsule
    question="Welchen Stil hat meine Hochzeitsfotografie?"
    answer="Authentisch und zeitlos. Ich arbeite im Stil einer ruhigen Hochzeitsreportage: Ich halte fest, was wirklich passiert, statt es zu inszenieren. Echte Emotionen — das Lachen, die Freudentränen, der Blick zwischendurch — wirken auch in zehn Jahren noch, während Modetrends verblassen. Bilder, die sich echt anfühlen."
  />

  <Capsule
    question="Welche Leistungen biete ich als Hochzeitsfotografin an?"
    answer="Ich begleite den ganzen Hochzeitstag — vom Getting-ready über die Trauung am Standesamt oder die freie Trauung bis zum Fest. Auf Wunsch ein Paarshooting vorab und ein Hochzeitsvideo dazu. Ihre fertigen Hochzeitsfotos erhalten Sie in einer privaten Online-Galerie zum Herunterladen."
  >
    <div class="flex flex-wrap gap-4">
      <a href="/video/" class="text-sm font-medium text-[var(--color-clay)] hover:text-[var(--color-clay-dark)]">Mehr zu Video →</a>
      <a href="/portfolio/" class="text-sm font-medium text-[var(--color-clay)] hover:text-[var(--color-clay-dark)]">Portfolio ansehen →</a>
    </div>
  </Capsule>

  <Capsule
    question="In welchen Regionen fotografiere ich Hochzeiten?"
    answer="Ich fotografiere in der ganzen Deutschschweiz — mit Schwerpunkt Basel und meiner Heimatregion Aargau. Weitere Regionen wie Zürich, Bern, Luzern und die Zentralschweiz sowie Solothurn gerne auf Anfrage. Als reisende Hochzeitsfotografin gibt es keinen Studio-Zwang: ich komme an Ihren Ort in der ganzen Schweiz."
  >
    <div class="mt-4 flex flex-wrap gap-3">
      {regions.map((r) => (
        <a href={r.href} class="rounded-full border border-[var(--color-sand)] px-4 py-2 text-sm transition-colors hover:border-[var(--color-clay)] hover:text-[var(--color-clay)]">
          Hochzeitsfotograf {r.label}
        </a>
      ))}
    </div>
  </Capsule>

  <Capsule
    question="Gibt es auch ein Hochzeitsvideo?"
    answer="Ja — Foto und Video kommen bei mir aus einer Hand, im gleichen Stil und ohne dass Sie zwei Teams koordinieren müssen. Das Hochzeitsvideo hält Stimmen, Reden und Bewegung fest, was ein Standbild nicht kann: die Fotos für die Wand, der Film zum Wiedererleben Ihres grossen Tages."
  >
    <!-- TODO: bietet Mariluz eine Fotobox an? Falls ja, hier als Zusatzleistung ergänzen (Term „Fotobox" gefragt) -->
    <a href="/video/" class="text-sm font-medium text-[var(--color-clay)] hover:text-[var(--color-clay-dark)]">Mehr zu Hochzeitsvideo →</a>
  </Capsule>

  <Capsule
    question="Wie läuft die Zusammenarbeit ab?"
    answer="Wir lernen uns vor der Hochzeit kennen — persönlich oder per Video —, damit ich Ihre Wünsche und den Ablauf des Hochzeitstags kenne. Am grossen Tag fügt sich alles ineinander: Sie geniessen, ich begleite im Hintergrund. Danach sichte und bearbeite ich die Aufnahmen sorgfältig von Hand."
  />

  <Capsule
    question="Was ist enthalten, und wann bekomme ich die Bilder?"
    answer="Nach Ihrem Tag bearbeite ich die Hochzeitsfotos sorgfältig und stelle Ihnen Ihre Hochzeit als hochauflösende Online-Galerie zum Herunterladen bereit — auf Wunsch dazu das Hochzeitsvideo. Ablauf und Wünsche klären wir schon vorab, damit am grossen Tag alles besprochen ist."
  >
    <!-- TODO: konkrete Lieferzeit + ungefähre Bildanzahl nach Mariluz-Input präzisieren -->
  </Capsule>

  <Capsule
    question="Wie finde ich den passenden Hochzeitsfotografen?"
    answer="Achten Sie weniger auf einzelne schöne Bilder als auf einen durchgehenden Stil, der Ihnen gefällt — und darauf, ob beim Kennenlernen die Chemie stimmt. Sie verbringen den ganzen Tag miteinander. Schauen Sie sich am besten eine komplette Hochzeit im Portfolio an, nicht nur die Höhepunkte."
  >
    <a href="/portfolio/" class="text-sm font-medium text-[var(--color-clay)] hover:text-[var(--color-clay-dark)]">Ganze Hochzeiten im Portfolio →</a>
  </Capsule>

  <Capsule
    question="Was kostet ein Hochzeitsfotograf in der Schweiz?"
    answer="Jede Hochzeit ist anders — Umfang, Dauer und ob Foto, Video oder beides gewünscht ist. Deshalb erstelle ich Ihnen ein individuelles Angebot in CHF statt Pauschalpreise von der Stange. Fragen Sie unverbindlich an, und wir besprechen, was zu Ihrem Tag passt."
  >
    <!-- TODO: konkrete Pakete/Preise nach Preis-Research + Mariluz-Input -->
    <a href="/kontakt/" class="text-sm font-medium text-[var(--color-clay)] hover:text-[var(--color-clay-dark)]">Angebot anfragen →</a>
  </Capsule>

  <Capsule
    question="Wie früh sollte ich meine Hochzeit anfragen?"
    answer="So früh wie möglich. Beliebte Hochzeitsdaten — vor allem an Wochenenden im Sommer — sind oft ein Jahr im Voraus vergeben. Sobald Datum und Ort feststehen, lohnt sich die Anfrage. Dann bleibt genug Zeit für ein Kennenlernen, bevor wir Ihren Hochzeitstag gemeinsam planen."
  >
    <a href="/kontakt/" class="inline-block rounded-full bg-[var(--color-clay)] px-6 py-3 text-sm font-medium text-white transition-colors hover:bg-[var(--color-clay-dark)]">Verfügbarkeit anfragen</a>
  </Capsule>
</BaseLayout>
