---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import Capsule from '../components/Capsule.astro';
import { SITE } from '../consts';
import { service } from '../lib/schema';

const alternates = [
  { lang: 'de-CH', href: `${SITE.url}/hochzeitsfotograf/` },
  { lang: 'es', href: `${SITE.url}/es/fotografo-bodas/` },
];

const regions = [
  { label: 'Basel', href: '/hochzeitsfotograf-basel/' },
  { label: 'Aargau', href: '/hochzeitsfotograf-aargau/' },
];
---

<BaseLayout
  title="Hochzeitsfotograf — Foto & Video | Mariluz Fotografía"
  description="Hochzeitsfotografin für emotionale, authentische Bilder — Foto und Video aus einer Hand, in der ganzen Deutschschweiz. Über 20 Jahre Erfahrung."
  path="/hochzeitsfotograf/"
  alternates={alternates}
  schema={service({
    name: 'Hochzeitsfotografie & -video',
    description: 'Foto- und Videobegleitung für Hochzeiten in der Deutschschweiz.',
    serviceType: 'Hochzeitsfotografie',
  })}
>
  <Hero
    eyebrow="Hochzeit · Foto & Video"
    title="Ihre Hochzeit, ehrlich und emotional festgehalten"
    lead="Von der Vorbereitung bis zum letzten Tanz — ich begleite Ihren Tag mit Foto und Video, unaufdringlich und mit dem Blick für den echten Moment."
    ctaHref="/kontakt/"
    ctaLabel="Verfügbarkeit anfragen"
  />

  <Capsule
    question="Wie begleite ich eine Hochzeit?"
    answer="Ich bin den ganzen Tag dabei, ohne im Weg zu stehen — für die stillen Blicke ebenso wie für die grossen Momente. Foto und Video aus einer Hand, damit Ihr Tag als Bild und als bewegte Erinnerung erhalten bleibt. Nach über 20 Jahren weiss ich, wann der richtige Augenblick kommt."
  />

  <Capsule
    question="In welchen Regionen fotografiere ich Hochzeiten?"
    answer="Ich bin in der ganzen Deutschschweiz unterwegs — mit Schwerpunkt Basel und meiner Heimatregion Aargau. Weitere Regionen wie Zürich, Bern, Luzern und Solothurn auf Anfrage. Als reisende Fotografin gibt es keinen Studio-Zwang: ich komme an Ihren Ort."
  >
    <div class="mt-4 flex flex-wrap gap-3">
      {regions.map((r) => (
        <a href={r.href} class="rounded-full border border-[var(--color-sand)] px-4 py-2 text-sm transition-colors hover:border-[var(--color-clay)] hover:text-[var(--color-clay)]">
          Hochzeitsfotograf {r.label}
        </a>
      ))}
    </div>
  </Capsule>

  <Capsule
    question="Was kostet eine Hochzeitsbegleitung?"
    answer="Jede Hochzeit ist anders — Umfang, Dauer und ob Foto, Video oder beides gewünscht ist. Deshalb erstelle ich Ihnen ein individuelles Angebot statt Pauschalpreise von der Stange. Fragen Sie unverbindlich an, und wir besprechen, was zu Ihrem Tag passt."
  >
    <!-- TODO: konkrete Pakete/Preise nach Preis-Research + Mariluz-Input -->
    <a href="/kontakt/" class="text-sm font-medium text-[var(--color-clay)] hover:text-[var(--color-clay-dark)]">Angebot anfragen →</a>
  </Capsule>
</BaseLayout>
