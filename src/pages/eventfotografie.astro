---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import Capsule from '../components/Capsule.astro';
import { SITE } from '../consts';
import { service } from '../lib/schema';

const alternates = [
  { lang: 'de-CH', href: `${SITE.url}/eventfotografie/` },
  { lang: 'es', href: `${SITE.url}/es/fotografo-eventos/` },
];
---
<BaseLayout
  title="Eventfotograf — Feste & Anlässe | Mariluz Fotografía"
  description="Eventfotografie für Feste, Feiern und Anlässe in der Deutschschweiz. Foto und Video, die die Stimmung Ihres Events einfangen."
  path="/eventfotografie/"
  alternates={alternates}
  schema={service({ name: 'Eventfotografie', description: 'Foto und Video für Feste und Anlässe in der Deutschschweiz.', serviceType: 'Eventfotografie' })}
>
  <Hero eyebrow="Events & Feste" title="Eventfotografie mit Gespür für den Moment"
    lead="Ob Geburtstag, Jubiläum oder Familienfest — ich halte die Stimmung Ihres Anlasses fest, in Foto und Video."
    ctaHref="/kontakt/" ctaLabel="Event anfragen" />

  <Capsule question="Welche Events begleite ich?"
    answer="Private Feiern jeder Art — Geburtstage, Jubiläen, Taufen, Familienfeste und kulturelle Anlässe. Ich bewege mich unauffällig durch den Abend und fange echte Reaktionen ein statt gestellter Gruppenbilder. Auf Wunsch Foto und Video aus einer Hand." />

  <Capsule question="Wie arbeite ich an einem Event?"
    answer="Zurückhaltend und aufmerksam. Ich dränge mich nicht ins Geschehen, sondern lese den Abend — das Lachen, den Anstoss, den stillen Moment am Rand. So bleibt die Feier eine Feier, und die Bilder erzählen später, wie es wirklich war. Nach über 20 Jahren spüre ich, wann der Auslöser kommt." />

  <Capsule question="Foto und Video für Ihren Anlass?"
    answer="Beides aus einer Hand. Neben den Fotos halte ich Ihr Event auf Wunsch als Video fest — die Musik, die Reden, die Bewegung des Abends. Sie koordinieren keine zwei Dienstleister: ein Ansprechpartner, ein Stil, ein stimmiges Ergebnis zum Ansehen und Wiedererleben.">
    <a href="/video/" class="text-sm font-medium text-[var(--color-clay)] hover:text-[var(--color-clay-dark)]">Mehr zu Video →</a>
  </Capsule>

  <Capsule question="In welchen Regionen fotografiere ich Events?"
    answer="In der ganzen Deutschschweiz — mit Schwerpunkt Aargau, wo ich zuhause bin, und Basel. Als reisende Fotografin komme ich an Ihren Ort, ob Restaurant, Festsaal oder Garten. Weitere Regionen wie Zürich, Luzern und Solothurn gerne auf Anfrage." />

  <Capsule question="Was kostet ein Eventfotograf?"
    answer="Das hängt von Dauer, Anlass und davon ab, ob Sie Foto, Video oder beides möchten. Statt Pauschalen erstelle ich Ihnen ein individuelles Angebot, das zu Ihrem Fest passt. Melden Sie sich mit Datum, Ort und ungefährer Dauer — ich melde mich zeitnah zurück.">
    <!-- TODO: konkrete Pakete/Preise nach Preis-Research + Mariluz-Input -->
    <!-- TODO: Firmenevents/Business-Fotografie verlinken sobald /business-fotografie/ gebaut -->
    <a href="/kontakt/" class="inline-block rounded-full bg-[var(--color-clay)] px-6 py-3 text-sm font-medium text-white transition-colors hover:bg-[var(--color-clay-dark)]">Event anfragen</a>
  </Capsule>
</BaseLayout>
