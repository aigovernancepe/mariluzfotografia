---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import Capsule from '../../components/Capsule.astro';
import { SITE } from '../../consts';
import { service } from '../../lib/schema';

const alternates = [
  { lang: 'de-CH', href: `${SITE.url}/schwangerschaftsfotos/` },
  { lang: 'es', href: `${SITE.url}/es/fotografo-embarazo/` },
];
---
<BaseLayout lang="es"
  title="Fotógrafo de embarazo en Suiza — Foto y Video | Mariluz Fotografía"
  description="Sesión de fotos de embarazo en Suiza. Retratos cálidos y delicados de tu dulce espera — foto y video, con más de 20 años de experiencia."
  path="/es/fotografo-embarazo/" alternates={alternates}
  schema={service({ name: 'Fotografía de embarazo', description: 'Sesiones de fotografía de embarazo en Suiza.', serviceType: 'Fotografía de embarazo', areaServed: 'Suiza' })}
>
  <Hero eyebrow="Embarazo" title="Fotógrafo de embarazo en Suiza"
    lead="Esa espera tan especial pasa rápido. La guardo con delicadeza y calma — para recuerdos que quedan."
    ctaHref="/es/contacto/" ctaLabel="Reservar sesión" />
  <Capsule question="¿Cuál es el mejor momento para la sesión de embarazo?"
    answer="Normalmente entre la semana 28 y 34: la pancita ya se ve bonita y redonda, y tú aún te mueves con comodidad. Planeamos la sesión con calma y tiempo para pausas. Sola, en pareja o con los hermanitos: la adaptamos a lo que más te guste." />
  <!-- TODO: detalle, ubicaciones, opción foto+video -->
</BaseLayout>
