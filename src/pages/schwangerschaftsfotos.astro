---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import Capsule from '../components/Capsule.astro';
import { SITE } from '../consts';
import { service } from '../lib/schema';

const alternates = [
  { lang: 'de-CH', href: `${SITE.url}/schwangerschaftsfotos/` },
  { lang: 'es', href: `${SITE.url}/es/fotografo-embarazo/` },
];
---
<BaseLayout
  title="Schwangerschaftsfotos — Babybauch-Shooting | Mariluz Fotografía"
  description="Schwangerschaftsfotos in der Deutschschweiz. Feinfühlige Babybauch-Shootings, die die Vorfreude festhalten — Foto und Video, bei Ihnen zuhause oder in der Natur."
  path="/schwangerschaftsfotos/"
  alternates={alternates}
  schema={service({ name: 'Schwangerschaftsfotografie', description: 'Babybauch- und Schwangerschaftsfotos in der Deutschschweiz.', serviceType: 'Schwangerschaftsfotografie' })}
>
  <Hero eyebrow="Schwangerschaft" title="Schwangerschaftsfotos voller Vorfreude"
    lead="Diese besondere Zeit vergeht schnell. Ich halte sie feinfühlig und in Ruhe fest — für Erinnerungen, die bleiben."
    ctaHref="/kontakt/" ctaLabel="Termin anfragen" />

  <Capsule question="Wann ist der richtige Zeitpunkt für Schwangerschaftsfotos?"
    answer="Meist zwischen der 28. und 34. Schwangerschaftswoche — der Bauch ist schön rund, und Sie fühlen sich noch beweglich. Wir planen den Termin entspannt, mit genug Zeit für Pausen. Ob Partner, Geschwister oder allein: Wir gestalten das Shooting so, wie es zu Ihnen passt." />

  <Capsule question="Wie läuft ein Babybauch-Shooting ab?"
    answer="Ganz in Ruhe und in Ihrem Tempo. Wir nehmen uns Zeit, damit Sie ankommen und sich wohlfühlen — nichts wird gehetzt. Ich führe Sie behutsam durch sanfte, natürliche Posen, die den Bauch schön zur Geltung bringen, ohne gestellt zu wirken. Pausen gehören selbstverständlich dazu." />

  <Capsule question="Wo entstehen die Bilder, und was ziehe ich an?"
    answer="Zuhause im vertrauten Licht, draussen in der Natur oder an einem Ort, der Ihnen etwas bedeutet — Sie entscheiden. Bei der Kleidung gilt: schlicht und figurbetont wirkt am schönsten. Bringen Sie gern zwei, drei Outfits mit, dann finden wir gemeinsam heraus, was zu Ihnen passt.">
    <!-- TODO: falls Fundus/Tücher vorhanden, hier konkret nennen -->
  </Capsule>

  <Capsule question="Können Partner und Geschwister dabei sein?"
    answer="Sehr gern. Schwangerschaft ist ein Familienmoment — Ihr Partner und die grösseren Geschwister sind herzlich willkommen. Gemeinsame Aufnahmen, in denen sich alle auf das neue Familienmitglied freuen, gehören oft zu den berührendsten Bildern des Shootings. Sagen Sie einfach vorab Bescheid, wer dabei sein möchte." />

  <Capsule question="Foto und Video — geht beides?"
    answer="Ja, beides aus einer Hand. Auf Wunsch halte ich die Vorfreude nicht nur als Foto, sondern auch als kurzes Video fest — ruhig und stimmungsvoll. Ein Ansprechpartner, ein Stil: die Standbilder für die Wand, der Film als bewegte Erinnerung an diese besondere Zeit.">
    <a href="/video/" class="text-sm font-medium text-[var(--color-clay)] hover:text-[var(--color-clay-dark)]">Mehr zu Video →</a>
  </Capsule>

  <Capsule question="Was kostet ein Schwangerschaftsshooting?"
    answer="Das richtet sich nach Dauer, Ort und danach, ob Sie nur Fotos oder auch Video möchten. Statt Pauschalen erstelle ich Ihnen ein individuelles Angebot, das zu Ihren Wünschen passt. Fragen Sie unverbindlich an — am besten frühzeitig, damit wir den richtigen Zeitpunkt in Ruhe planen können.">
    <!-- TODO: konkrete Pakete/Preise nach Preis-Research + Mariluz-Input -->
    <a href="/kontakt/" class="inline-block rounded-full bg-[var(--color-clay)] px-6 py-3 text-sm font-medium text-white transition-colors hover:bg-[var(--color-clay-dark)]">Termin anfragen</a>
  </Capsule>
</BaseLayout>
