---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import Capsule from '../components/Capsule.astro';
import { SITE } from '../consts';
import { service } from '../lib/schema';

const alternates = [
  { lang: 'de-CH', href: `${SITE.url}/familienfotografie/` },
  { lang: 'es', href: `${SITE.url}/es/fotografo-familiar/` },
];
---
<BaseLayout
  title="Familienfotografie — Foto & Video | Mariluz Fotografía"
  description="Natürliche Familien- und Kinderfotos in der Deutschschweiz. Entspannte Shootings, echte Momente — Foto und Video aus einer Hand, bei Ihnen zuhause oder draussen."
  path="/familienfotografie/"
  alternates={alternates}
  schema={service({ name: 'Familienfotografie', description: 'Familien- und Kinderfotografie in der Deutschschweiz.', serviceType: 'Familienfotografie' })}
>
  <Hero eyebrow="Familie & Kinder" title="Familienfotografie, die sich echt anfühlt"
    lead="Kein steifes Posieren — entspannte Bilder Ihrer Familie, so wie sie ist. In der ganzen Deutschschweiz, drinnen wie draussen."
    ctaHref="/kontakt/" ctaLabel="Shooting anfragen" />

  <Capsule question="Wie läuft ein Familienshooting ab?"
    answer="Wir treffen uns an einem Ort, an dem sich Ihre Familie wohlfühlt — zuhause, in der Natur oder am Lieblingsplatz. Ich lasse Raum für echte Momente statt gestellter Posen, gerade bei Kindern. So entstehen Bilder, die in ein paar Jahren noch nach Ihnen aussehen." />

  <Capsule question="Wo findet das Familienshooting statt?"
    answer="Dort, wo Sie sich am wohlsten fühlen. Bei Ihnen zuhause, im vertrauten Wohnzimmer, sind Kinder oft am entspanntesten. Draussen in Wald, Feld oder am Wasser entsteht viel Bewegung und Licht. Ich bin in der ganzen Deutschschweiz unterwegs und komme zu Ihnen — Sie müssen kein Studio aufsuchen." />

  <Capsule question="Funktioniert das auch mit kleinen Kindern und Babys?"
    answer="Gerade dann. Ich arbeite im Tempo Ihrer Kinder statt gegen es: Pausen, Spiel und ein bisschen Chaos gehören dazu. Aus dieser Leichtigkeit entstehen die schönsten Aufnahmen — ein Lachen, ein Blick, eine Umarmung. Nach über 20 Jahren weiss ich, dass Geduld mehr bringt als Anweisungen." />

  <Capsule question="Wie lange dauert ein Shooting, und wann bekomme ich die Bilder?"
    answer="Rechnen Sie mit rund ein bis zwei Stunden — genug Zeit, damit alle ankommen und sich lösen. Danach wähle und bearbeite ich die besten Aufnahmen sorgfältig von Hand. Die fertige Galerie erhalten Sie in der Regel innerhalb weniger Wochen digital zum Herunterladen.">
    <!-- TODO: konkrete Lieferzeit + Anzahl Bilder nach Mariluz-Input präzisieren -->
  </Capsule>

  <Capsule question="Foto und Video — geht beides?"
    answer="Ja, beides aus einer Hand. Neben den Fotos halte ich Ihre Familie auf Wunsch auch als kurzes Video fest — die Stimmen, die Bewegung, den Moment in echt. Ein Ansprechpartner, ein Stil, ein stimmiges Ergebnis für die Wand und zum Wiedererleben.">
    <a href="/video/" class="text-sm font-medium text-[var(--color-clay)] hover:text-[var(--color-clay-dark)]">Mehr zu Video →</a>
  </Capsule>

  <Capsule question="Was kostet ein Familienshooting?"
    answer="Das hängt von Dauer, Ort und davon ab, ob Sie nur Fotos oder auch Video möchten. Statt Pauschalpreisen von der Stange erstelle ich Ihnen ein individuelles Angebot, das zu Ihrer Familie passt. Fragen Sie unverbindlich an — wir besprechen in Ruhe, was Sie sich wünschen.">
    <!-- TODO: konkrete Pakete/Preise nach Preis-Research + Mariluz-Input -->
    <a href="/kontakt/" class="inline-block rounded-full bg-[var(--color-clay)] px-6 py-3 text-sm font-medium text-white transition-colors hover:bg-[var(--color-clay-dark)]">Shooting anfragen</a>
  </Capsule>
</BaseLayout>
