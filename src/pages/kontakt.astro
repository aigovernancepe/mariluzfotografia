---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import Capsule from '../components/Capsule.astro';
import ContactForm from '../components/ContactForm.astro';
import { SITE, NAP, SOCIAL } from '../consts';

const alternates = [
  { lang: 'de-CH', href: `${SITE.url}/kontakt/` },
  { lang: 'es', href: `${SITE.url}/es/contacto/` },
];
---

<BaseLayout
  title="Kontakt — Mariluz Fotografía"
  description="Fragen Sie Ihren Termin für Foto und Video an. Mariluz Fotografía — in der ganzen Deutschschweiz, zuhause in Menziken (Aargau)."
  path="/kontakt/"
  alternates={alternates}
>
  <Hero
    eyebrow="Kontakt"
    title="Sprechen wir über Ihren Anlass"
    lead="Erzählen Sie mir von Ihrer Feier — Datum, Ort und ob Sie Foto, Video oder beides möchten. Ich melde mich zeitnah mit einem individuellen Angebot."
  />

  <Capsule
    question="So erreichen Sie mich"
    answer="Am schnellsten per E-Mail oder Telefon. Nennen Sie mir Datum und Ort Ihrer Feier sowie die gewünschte Leistung — dann bekommen Sie rasch eine Rückmeldung. Beliebte Hochzeits- und Feiertermine sind früh vergeben, fragen Sie also rechtzeitig an."
  >
    <div class="mt-4 space-y-1 text-[var(--color-ink)]">
      <p><strong>Telefon:</strong> <a href={`tel:${NAP.phoneE164}`} class="text-[var(--color-clay)]">{NAP.phoneDisplay}</a></p>
      <p><strong>E-Mail:</strong> <a href={`mailto:${NAP.email}`} class="text-[var(--color-clay)]">{NAP.email}</a></p>
      <p><strong>Region:</strong> {NAP.city} ({NAP.region}) — Anfahrt in die ganze Deutschschweiz</p>
      <p>
        <strong>Instagram:</strong>
        <a
          href={SOCIAL.instagram}
          target="_blank"
          rel="me noopener"
          class="ml-1 inline-flex items-center gap-1.5 align-middle text-[var(--color-clay)] hover:text-[var(--color-clay-dark)]"
          aria-label={`Mariluz Fotografía auf Instagram (${SOCIAL.instagramHandle})`}
        >
          <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true">
            <path d="M12 2.2c3.2 0 3.6 0 4.9.07 1.17.05 1.8.25 2.23.42.56.22.96.48 1.38.9.42.42.68.82.9 1.38.17.42.37 1.06.42 2.23.06 1.27.07 1.65.07 4.87s0 3.6-.07 4.87c-.05 1.17-.25 1.8-.42 2.23-.22.56-.48.96-.9 1.38-.42.42-.82.68-1.38.9-.42.17-1.06.37-2.23.42-1.27.06-1.65.07-4.9.07s-3.6 0-4.87-.07c-1.17-.05-1.8-.25-2.23-.42a3.7 3.7 0 0 1-1.38-.9 3.7 3.7 0 0 1-.9-1.38c-.17-.42-.37-1.06-.42-2.23C2.2 15.6 2.2 15.2 2.2 12s0-3.6.07-4.87c.05-1.17.25-1.8.42-2.23.22-.56.48-.96.9-1.38.42-.42.82-.68 1.38-.9.42-.17 1.06-.37 2.23-.42C8.4 2.2 8.8 2.2 12 2.2Zm0 1.8c-3.15 0-3.52 0-4.76.07-.9.04-1.38.19-1.7.32-.43.16-.74.36-1.06.68-.32.32-.52.63-.68 1.06-.13.32-.28.8-.32 1.7C3.2 8.48 3.2 8.85 3.2 12s0 3.52.07 4.76c.04.9.19 1.38.32 1.7.16.43.36.74.68 1.06.32.32.63.52 1.06.68.32.13.8.28 1.7.32 1.24.07 1.61.07 4.76.07s3.52 0 4.76-.07c.9-.04 1.38-.19 1.7-.32.43-.16.74-.36 1.06-.68.32-.32.52-.63.68-1.06.13-.32.28-.8.32-1.7.07-1.24.07-1.61.07-4.76s0-3.52-.07-4.76c-.04-.9-.19-1.38-.32-1.7a2.85 2.85 0 0 0-.68-1.06 2.85 2.85 0 0 0-1.06-.68c-.32-.13-.8-.28-1.7-.32C15.52 4 15.15 4 12 4Zm0 3.06a4.94 4.94 0 1 1 0 9.88 4.94 4.94 0 0 1 0-9.88Zm0 1.8a3.14 3.14 0 1 0 0 6.28 3.14 3.14 0 0 0 0-6.28Zm5.14-.72a1.15 1.15 0 1 1-2.3 0 1.15 1.15 0 0 1 2.3 0Z"></path>
          </svg>
          {SOCIAL.instagramHandle}
        </a>
      </p>
    </div>
  </Capsule>

  <ContactForm lang="de" />
</BaseLayout>
