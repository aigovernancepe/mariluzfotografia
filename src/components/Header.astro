---
import { SITE, NAV_DE, NAV_ES } from '../consts';

interface Props { lang?: 'de' | 'es'; }
const { lang = 'de' } = Astro.props;

const nav = lang === 'es' ? NAV_ES : NAV_DE;
const home = lang === 'es' ? '/es/' : '/';
const switchLang = lang === 'es' ? { href: '/', label: 'DE' } : { href: '/es/', label: 'ES' };
---

<header class="border-b border-[var(--color-sand)] bg-[var(--color-ivory)]/95 sticky top-0 z-50 backdrop-blur">
  <div class="mx-auto flex max-w-6xl items-center justify-between px-5 py-4">
    <a href={home} class="font-serif text-xl tracking-tight text-[var(--color-ink)]">
      Mariluz <span class="text-[var(--color-clay)]">Fotografía</span>
    </a>

    <nav class="hidden items-center gap-6 md:flex">
      {nav.map((item) => (
        <a
          href={item.href}
          class="text-sm text-[var(--color-muted)] transition-colors hover:text-[var(--color-ink)]"
        >{item.label}</a>
      ))}
      <a
        href={switchLang.href}
        class="rounded-full border border-[var(--color-sand)] px-3 py-1 text-xs font-medium text-[var(--color-muted)] transition-colors hover:border-[var(--color-clay)] hover:text-[var(--color-clay)]"
      >{switchLang.label}</a>
    </nav>

    <a
      href={lang === 'es' ? '/es/contacto/' : '/kontakt/'}
      class="md:hidden rounded-full bg-[var(--color-clay)] px-4 py-2 text-xs font-medium text-white"
    >{lang === 'es' ? 'Contacto' : 'Kontakt'}</a>
  </div>
</header>
<span class="sr-only">{SITE.name}</span>
